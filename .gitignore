# Python
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Environment
.env
.env.local
.env.*.local

# Data & Models (large files — ignore by default, but committed artifacts are
# explicitly un-ignored below so `railway up` includes them in the upload)
data/*.csv
data/*.parquet
data/*.pkl
models/*.json
models/*.ubj
models/*.bin
!data/.gitkeep
!models/.gitkeep
# Committed model artifacts needed for Railway Docker build — must NOT be ignored
!models/health_scorer.ubj
!models/feature_baseline.parquet

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Eval run outputs
eval_runs/*/
!eval_runs/.gitkeep

# Docker
*.log

# Jupyter
.ipynb_checkpoints/
*.ipynb
.env
.env
