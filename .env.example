# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio_health

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── ML Model ──────────────────────────────────────────────────────────────────
MODEL_PATH=models/health_scorer.ubj      # XGBoost ubj format
FEATURE_BASELINE_PATH=models/feature_baseline.parquet

# ── yfinance / Data ───────────────────────────────────────────────────────────
PRICE_LOOKBACK_DAYS=365

# ── Monitoring ────────────────────────────────────────────────────────────────
PSI_THRESHOLD=0.2            # Population Stability Index alert threshold
SCORE_DRIFT_THRESHOLD=10.0   # abs mean shift in health score that triggers alert
