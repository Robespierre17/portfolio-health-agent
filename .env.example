# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio_health

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── ML Model ──────────────────────────────────────────────────────────────────
MODEL_PATH=models/health_scorer.ubj      # XGBoost ubj format
FEATURE_BASELINE_PATH=models/feature_baseline.parquet

# ── GCS model versioning (prod only) ──────────────────────────────────────────
# Entrypoint pulls gs://$GCS_BUCKET/models/$MODEL_VERSION/{health_scorer.ubj,feature_baseline.parquet}
# Leave blank in development — local artifact in models/ is used instead.
GCS_BUCKET=
MODEL_VERSION=v1.0.0

# ── yfinance / Data ───────────────────────────────────────────────────────────
PRICE_LOOKBACK_DAYS=365

# ── Monitoring ────────────────────────────────────────────────────────────────
PSI_THRESHOLD=0.2            # Population Stability Index alert threshold
SCORE_DRIFT_THRESHOLD=10.0   # abs mean shift in health score that triggers alert
